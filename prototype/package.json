{
  "name": "sophex-mvp0-prototype",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "budget:check": "node scripts/check-bundle-budget.mjs",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint .",
    "format:check": "prettier --check .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:stories": "vitest run src/test/stories.test.tsx",
    "test:stories:interactions": "vitest run src/test/stories.test.tsx -t \"play interactions\"",
    "test:coverage": "vitest run --coverage",
    "test:api": "vitest run src/test/sandbox-api.test.ts",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "test:e2e:visual": "playwright test e2e/visual.spec.ts --project=visual",
    "test:e2e:update-snapshots": "playwright test e2e/visual.spec.ts --project=visual --update-snapshots",
    "test:lighthouse": "lhci autorun --config=./lighthouserc.cjs",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "bundle:analyze": "vite build --mode analyze",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "framer-motion": "^11.18.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.0",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@lhci/cli": "^0.14.0",
    "@playwright/test": "^1.51.1",
    "@storybook/addon-a11y": "^8.6.14",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-interactions": "^8.6.14",
    "@storybook/react-vite": "^8.6.14",
    "@storybook/test": "^8.6.14",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^22.13.4",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.39.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jest-axe": "^10.0.0",
    "jsdom": "^26.0.0",
    "prettier": "^3.8.3",
    "rollup-plugin-visualizer": "^7.0.1",
    "storybook": "^8.6.14",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^6.0.11",
    "vitest": "^3.0.5"
  }
}
