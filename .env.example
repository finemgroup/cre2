# Sophex local development environment example.
# Copy values into a local ignored .env.local only after rotating any credentials
# that were exposed outside a secret manager.

# Pooled Neon URL for application/runtime clients.
# Example shape only; do not commit real credentials:
# postgresql://<user>:<rotated-password>@<pooled-host>/<database>?sslmode=require&channel_binding=require
CRE2_DATABASE_URL=

# Direct Neon URL for admin or migration tooling in a future approved DB lane.
# Do not use from the current schema-contract lane.
CRE2_DATABASE_URL_DIRECT=

# Current schema foundation lane does not execute SQL or connect to a DB.
SOPHEX_DB_CONNECTION_STATUS=not_configured

# Frontend runtime adapter mode.
# fixture = deterministic local prototype data.
# api = call the sandbox API adapter; set VITE_SOPHEX_API_BASE_URL for a remote API.
VITE_SOPHEX_RUNTIME_MODE=fixture
VITE_SOPHEX_API_BASE_URL=
